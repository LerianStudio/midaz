# Colors and formatting for Makefiles
# This file contains standardized color and formatting definitions
# included by the root Makefile and every component Makefile so the
# whole monorepo shares one terminal vocabulary.

# ANSI color codes
NC := \033[0m
BOLD := \033[1m
RED := \033[31m
MAGENTA := \033[35m
YELLOW := \033[33m
GREEN := \033[32m
CYAN := \033[36m
WHITE := \033[37m
