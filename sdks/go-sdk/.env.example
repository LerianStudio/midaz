# Midaz Go SDK Environment Variables

# Authentication token for the Midaz API
MIDAZ_AUTH_TOKEN=midaz-auth-token-123456

# API URLs (defaults to local development setup if not specified)
MIDAZ_ONBOARDING_URL=http://localhost:3000/v1
MIDAZ_TRANSACTION_URL=http://localhost:3001/v1

# Debug mode (set to true for verbose output)
MIDAZ_DEBUG=true

# Timeout in seconds for API requests
MIDAZ_TIMEOUT=30
