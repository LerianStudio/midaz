# ============================================
# Tracer v0.1 - Configuration Template
# Copy to .env and customize: cp .env.example .env
#
# ⚠️  WARNING: This file contains DEVELOPMENT defaults.
#     DO NOT use these values in production without modification.
#     See comments for production-safe configuration.
# ============================================

# ----------------
# Application
# ----------------
VERSION=v0.1.0
SERVER_PORT=4020
SERVER_ADDRESS=:${SERVER_PORT}

# DEPLOYMENT_MODE controls TLS enforcement at startup.
#   saas  — Lerian-hosted; TLS REQUIRED for all DSNs (hard-fail at boot)
#   byoc  — Customer-hosted; TLS recommended, not enforced
#   local — Developer workstation (default); TLS optional
DEPLOYMENT_MODE=local

# Per-connection TLS enforcement bypass (local development only).
# lib-commons v5.4.1 enforces TLS on every Postgres connection unless this is set,
# independently of DEPLOYMENT_MODE. The shared local Postgres (midaz-postgres-primary)
# runs without TLS (sslmode=disable), so the local stack requires this bypass to
# connect. NEVER set this in production.
ALLOW_INSECURE_TLS=true

# Authentication
# ⚠️  SECURITY WARNING - PRODUCTION SECRETS MANAGEMENT:
#     DO NOT use plain text secrets in production environments.
#     Use an external secrets manager instead:
#     - HashiCorp Vault: https://www.vaultproject.io/
#     - AWS Secrets Manager: https://aws.amazon.com/secrets-manager/
#     - Azure Key Vault: https://azure.microsoft.com/en-us/services/key-vault/
#     - Kubernetes External Secrets Operator: https://external-secrets.io/
#
# API_KEY: The API key for authenticating requests (min 32 characters in production)
# API_KEY_ENABLED: Set to true to enforce API key authentication
# API_KEY_LABEL: Audit actor identifier recorded when a request authenticates via
#                API key. Stored in audit_events.actor_id for compliance / forensic
#                attribution. Use a deployment-specific value in production
#                (e.g., "tracer-prod-eu", "tracer-saas-tenant-123") so audit logs
#                distinguish between API-key principals. Defaults to "tracer-default".
API_KEY=dev_api_key_32chars_change_in_prod
API_KEY_ENABLED=false
API_KEY_ENABLED_ONLY_VALIDATION=false
API_KEY_LABEL=tracer-default

# CORS (Cross-Origin Resource Sharing)
# CORS_ALLOWED_ORIGINS: Comma-separated list of allowed origins
# - Production: "https://app.example.com,https://admin.example.com"
# - Development: "*" (allows all origins - use only for local dev)
# - Empty/unset: restrictive (no cross-origin requests allowed)
#
# DEVELOPMENT: Uncomment the line below for local testing
# CORS_ALLOWED_ORIGINS=*
# PRODUCTION: Specify exact origins (default is restrictive)
CORS_ALLOWED_ORIGINS=

# POSTGRES
# ⚠️  DB_PASSWORD: Use external secrets manager in production (see Authentication section above)
#
# DEVELOPMENT: Use values below for local Docker setup
# PRODUCTION: Use secrets manager, enable SSL (DB_SSL_MODE=require or verify-full)
# Tracer connects to the SHARED midaz Postgres primary (postgres:17) on the
# infra-network — there is no standalone tracer-postgres anymore. The `tracer`
# database is provisioned by components/infra/postgres/init.sql on a fresh
# volume (see that file for the existing-volume runbook note). Credentials match
# the shared instance (POSTGRES_USER/PASSWORD in components/infra/.env).
DB_HOST=midaz-postgres-primary
DB_USER=midaz
DB_PASSWORD=lerian
DB_NAME=tracer
DB_PORT=5701
DB_SSL_MODE=disable
MIGRATIONS_PATH=./migrations

# ----------------
# Swagger Documentation
# ----------------
SWAGGER_TITLE='Tracer API'
SWAGGER_DESCRIPTION='Real-time transaction validation and fraud prevention API'
SWAGGER_VERSION=${VERSION}
SWAGGER_HOST=${SERVER_ADDRESS}
SWAGGER_BASE_PATH=/
SWAGGER_SCHEMES=http
SWAGGER_LEFT_DELIMITER={{
SWAGGER_RIGHT_DELIMITER=}}

# ----------------
# Logging
# ----------------
LOG_LEVEL=debug

# ----------------
# CEL Expression Engine
# ----------------
# CEL_COST_LIMIT: Maximum cost for CEL expression evaluation (default: 10000)
# Higher values allow more complex expressions but may impact performance
CEL_COST_LIMIT=10000

# ----------------
# OpenTelemetry (Observability)
# ----------------
OTEL_RESOURCE_SERVICE_NAME=tracer
OTEL_LIBRARY_NAME=github.com/LerianStudio/tracer
OTEL_RESOURCE_SERVICE_VERSION=${VERSION}
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT=tracer-jaeger:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}
ENABLE_TELEMETRY=true

# ----------------
# Usage Cleanup Worker
# ----------------
# Background worker that periodically cleans up expired usage counters
# CLEANUP_WORKER_ENABLED: Enable/disable the background cleanup worker (default: false)
# CLEANUP_INTERVAL_HOURS: How often cleanup runs in hours (default: 24)
# CLEANUP_RETENTION_DAYS: How long to keep counters in days (default: 90)
CLEANUP_WORKER_ENABLED=false
CLEANUP_INTERVAL_HOURS=24
CLEANUP_RETENTION_DAYS=90

# ----------------
# Plugin Authentication
# ----------------
# PLUGIN_AUTH_ADDRESS: URL of the authentication service for plugins
# PLUGIN_AUTH_ENABLED: Set to true to enable plugin authentication (default: false)
PLUGIN_AUTH_ADDRESS=http://localhost:4000
PLUGIN_AUTH_ENABLED=false

# Rule Sync Worker
# ----------------
# Background worker that polls for rule changes and updates the in-memory cache
# RULE_SYNC_POLL_INTERVAL_SECONDS: How often to poll for changes in seconds (default: 10)
# RULE_SYNC_STALENESS_THRESHOLD_SECONDS: Cache staleness threshold for health checks in seconds (default: 50)
# RULE_SYNC_OVERLAP_BUFFER_SECONDS: Overlap buffer for delta queries in seconds (default: 2)
RULE_SYNC_POLL_INTERVAL_SECONDS=10
RULE_SYNC_STALENESS_THRESHOLD_SECONDS=50
RULE_SYNC_OVERLAP_BUFFER_SECONDS=2

# ----------------
# Graceful Shutdown
# ----------------
# READYZ_DRAIN_GRACE_SECONDS controls how long /readyz returns 503 after
# SIGTERM before deps are closed. Sized for K8s readinessProbe defaults
# (periodSeconds=5, failureThreshold=2 ⇒ 10s) plus a small buffer so the
# kubelet has observed the 503 and stopped routing traffic before the
# HTTP server begins shutting down. Default: 12.
READYZ_DRAIN_GRACE_SECONDS=12

# READYZ_CACHE_STALENESS_THRESHOLD_SECONDS controls the rule_cache staleness
# threshold for the /readyz dependency probe. When the cache's staleness
# exceeds this value, the rule_cache check flips to "degraded" and /readyz
# returns 503. Default: 300 (5 min) — sized to outlive realistic Postgres
# failover windows so a brief DB hiccup does not cycle every pod. SREs with
# tighter SLOs can shorten this without a code change. A non-positive value
# falls back to the default.
READYZ_CACHE_STALENESS_THRESHOLD_SECONDS=300

# ============================================================================
# Application Identity
# ============================================================================

# Application name. Used as the module identifier when registering with the
# multi-tenant Tenant Manager. Default: "tracer".
APPLICATION_NAME=tracer

# ============================================================================
# Multi-Tenant (Optional — leave MULTI_TENANT_ENABLED=false for single-tenant)
# ============================================================================
# When MULTI_TENANT_ENABLED=true, tracer resolves per-tenant Postgres pools
# via the Tenant Manager and receives tenant lifecycle events via Redis Pub/Sub.
# Redis is provisioned alongside the Tenant Manager (platform infra) — tracer
# does NOT own a Redis instance. Point MULTI_TENANT_REDIS_HOST to the shared Redis.

MULTI_TENANT_ENABLED=false

# Tenant Manager HTTP address. Required when enabled.
# PRODUCTION: MUST be https://. Cleartext http:// is rejected unless
# MULTI_TENANT_ALLOW_INSECURE_HTTP=true is set explicitly (dev/test only).
MULTI_TENANT_URL=

# Allow cleartext http:// for MULTI_TENANT_URL. Must be true to opt in to
# sending the service API key in plaintext. NEVER set in production — keep false.
MULTI_TENANT_ALLOW_INSECURE_HTTP=false

# API key for calling the Tenant Manager's /settings endpoint. Required when enabled.
MULTI_TENANT_SERVICE_API_KEY=

# Redis (Tenant Manager's shared instance) for Pub/Sub tenant lifecycle events.
# Required when enabled.
MULTI_TENANT_REDIS_HOST=
MULTI_TENANT_REDIS_PORT=6379
MULTI_TENANT_REDIS_PASSWORD=
# TLS for the tenant-events Redis Pub/Sub connection. Defaults to true when the
# env var is unset (secure default, H14). Set to false ONLY for local dev with
# unencrypted Redis — a strong WARN banner is logged at boot in that case.
# SECURITY NOTE: Redis Pub/Sub has no per-message authentication — any publisher
# on the channel can emit tenant.deleted events and trigger cache eviction across
# all tracer pods. Restrict PUBLISH on the tenant-events channel to the Tenant
# Manager identity via Redis ACL.
MULTI_TENANT_REDIS_TLS=true

# Connection manager behavior.
#
# MULTI_TENANT_MAX_TENANT_POOLS caps the number of distinct tenants that can
# hold live Postgres pools on one tracer pod.
#
# ──────────────────────────────────────────────────────────────────────────
# Sizing the multi-tenant connection budget
# ──────────────────────────────────────────────────────────────────────────
#
# Per replica, total Postgres connections =
#   MAX_TENANT_POOLS × MAX_OPEN_CONNS_PER_TENANT × <number of service replicas>
#
# Stay under 80% of pg.max_connections to leave headroom for migrations,
# admin sessions, and connection bursts.
#
# Three knobs to balance:
#
#   1. MULTI_TENANT_MAX_TENANT_POOLS — the LRU bound on tenants kept hot.
#      Lowering this evicts cold tenants more aggressively, which causes
#      pool re-creation thrash if your active-tenant set is larger.
#
#   2. MULTI_TENANT_MAX_OPEN_CONNS_PER_TENANT — concurrency limit per pool.
#      Lowering this lets more tenants stay hot without exceeding the budget,
#      at the cost of request queuing inside each tenant. Leave at 0 to use
#      the lib-commons default of 25 max-open / 10 max-idle.
#
#   3. pg.max_connections (Postgres-side) — the hard ceiling. Each conn
#      costs ~10 MB on the server. Bumping this is the cleanest fix when
#      tenant count and per-tenant concurrency must both stay high.
#
# Worked examples (pg.max_connections=500 → budget ≈ 400, 3 replicas):
#
#   - Few active tenants, full concurrency:
#       MAX_TENANT_POOLS=5, MAX_OPEN_CONNS_PER_TENANT=25
#       → 5 × 25 × 3 = 375 conns (best when ≤5 tenants are usually hot)
#
#   - Many active tenants, smaller per-tenant pool:
#       MAX_TENANT_POOLS=10, MAX_OPEN_CONNS_PER_TENANT=13
#       → 10 × 13 × 3 = 390 conns (best when 6-10+ tenants are hot)
#
#   - High concurrency required, scale Postgres instead:
#       MAX_TENANT_POOLS=10, MAX_OPEN_CONNS_PER_TENANT=25, pg.max_connections=1000
#       → 10 × 25 × 3 = 750 conns (requires bumping the PG ceiling first)
#
# Anti-pattern (DO NOT use): MAX_TENANT_POOLS=10 with default per-tenant
# size of 25 and pg.max_connections=500 → 750 conns will exhaust PG.
# ──────────────────────────────────────────────────────────────────────────
#
# When the cap is reached the supervisor stops spawning new tenant workers and
# /v1 returns 503 with Retry-After=<TENANT_CAP_RETRY_AFTER_SECONDS> and the
# canonical {code: TRC-0335} envelope.
MULTI_TENANT_MAX_TENANT_POOLS=100
# Retry-After (seconds) emitted alongside the 503 response when the per-tenant
# worker supervisor declines a request because MULTI_TENANT_MAX_TENANT_POOLS
# is full. Operators tune this if their callers need a longer back-off (e.g.
# noisy clients on a saturated cluster). Must be a positive integer; zero,
# negative, or non-numeric values silently fall back to the default of 5s.
TENANT_CAP_RETRY_AFTER_SECONDS=5
# Idle timeout after which an unused tenant pool is torn down. Cold-start cost
# on the next request for that tenant is ~100-700ms (new pool + first query).
# For bursty workloads (e.g. nightly batch), increase to 1800 (30m) or 3600
# (1h) to trade pool-pressure for predictable latency.
MULTI_TENANT_IDLE_TIMEOUT_SEC=300
MULTI_TENANT_TIMEOUT=30

# Circuit breaker on the Tenant Manager HTTP client.
MULTI_TENANT_CIRCUIT_BREAKER_THRESHOLD=5
MULTI_TENANT_CIRCUIT_BREAKER_TIMEOUT_SEC=30

# Local cache TTL for tenant config (reduces pressure on Tenant Manager).
#
# With Redis Pub/Sub healthy, credential rotations propagate to every tracer
# pod in under 1s (TENANT_UPDATED event). This TTL is the FALLBACK staleness
# bound when Pub/Sub is unavailable: a rotation that slipped past the event
# channel is visible to tracer within CACHE_TTL_SEC seconds. Lower values
# tighten the rotation window but increase RPS on the Tenant Manager; higher
# values ease TM load but extend the rotation-blind window.
MULTI_TENANT_CACHE_TTL_SEC=120

# Async revalidation interval for per-tenant PG pools (via WithConnectionsCheckInterval).
MULTI_TENANT_CONNECTIONS_CHECK_INTERVAL_SEC=30
