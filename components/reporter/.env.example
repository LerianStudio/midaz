# IMPORTANT: Copy this file to .env and replace all CHANGE_ME values
# with strong, unique passwords before running the application.
# Never commit real credentials to version control.

# RUN_MODE selects which surfaces the unified reporter binary runs:
#   api    — REST API surface only (production api Deployment, :4005)
#   worker — RabbitMQ consumer + health server only (production worker Deployment, :4006)
#   all    — both surfaces in one process (DEV ONLY; default when unset)
# The component docker-compose overrides RUN_MODE per service (reporter-api=api,
# reporter-worker=worker); this value applies to bare `docker run` / local runs.
RUN_MODE=all

# Application
ENV_NAME=development
VERSION=v4.0.0
APP_CONTEXT=/manager/v1
SERVER_PORT=4005
SERVER_ADDRESS=":${SERVER_PORT}"
LOG_LEVEL=debug

# Health Server (worker surface) — liveness (/health) and readiness (/readyz)
HEALTH_PORT=4006

# DEPLOYMENT_MODE controls SaaS TLS enforcement at boot.
#   saas  — Lerian-hosted; HARD-FAILS the boot if any DSN
#           (Mongo / RabbitMQ / Redis / Storage / Tenant Manager / MT-Redis)
#           is configured without TLS. Use for Lerian-hosted production.
#   byoc  — customer-hosted; TLS recommended but not enforced.
#   local — default for dev workstations and CI; no enforcement.
# This value is echoed in the /readyz response (top-level deployment_mode field).
DEPLOYMENT_MODE=local

# ALLOW_INSECURE_TLS bypasses production/SaaS TLS enforcement when truthy.
#   false — enforce TLS: REDIS_TLS, MULTI_TENANT_REDIS_TLS,
#           OBJECT_STORAGE_DISABLE_SSL, RABBITMQ AMQPS, and the
#           DEPLOYMENT_MODE=saas ValidateSaaSTLS gate are all required.
#   true  — skip the TLS-related checks above (mirrors lib-commons
#           ALLOW_INSECURE_TLS). Non-TLS prod checks (telemetry, auth,
#           secrets, CORS) still apply. Use only for transitional or
#           non-production deployments that intentionally run plaintext.
# Local default is true: the shared midaz infra (RabbitMQ / Mongo / Valkey /
# SeaweedFS) runs plaintext on infra-network, so the local stack requires this
# bypass to connect — matching ledger/tracer. NEVER set this in production.
ALLOW_INSECURE_TLS=true

# CORS (API surface) — comma-separated origins, wildcard (*) only in development
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-ID

# Trusted Proxies (API surface) — comma-separated IPs/CIDRs for X-Forwarded-For resolution
TRUSTED_PROXIES=

# MongoDB — points at midaz's shared infra service (components/infra)
#MONGO_URI=mongo+srv
MONGO_URI=mongodb
MONGO_HOST=midaz-mongodb
MONGO_NAME=reporter-db
MONGO_USER=midaz
MONGO_PASSWORD=lerian
MONGO_PORT=5703
MONGO_MAX_POOL_SIZE=1000
MONGO_PARAMETERS=
# Base64-encoded PEM CA certificate for MongoDB TLS (optional)
MONGO_TLS_CA_CERT=

# RabbitMQ — points at midaz's shared infra service (components/infra, 4.1.3).
# On the shared broker rabbitmq.conf binds the AMQP listener to 3003 and the
# management HTTP API to 3004. Reporter dials AMQP using RABBITMQ_PORT_AMQP and
# probes the management API via RABBITMQ_PORT_HOST, so the two map as below.
RABBITMQ_URI=amqp
RABBITMQ_HOST=midaz-rabbitmq
RABBITMQ_PORT_AMQP=3003
RABBITMQ_PORT_HOST=3004
RABBITMQ_DEFAULT_USER=midaz
RABBITMQ_DEFAULT_PASS=lerian
RABBITMQ_EXCHANGE=reporter.generate-report.exchange
RABBITMQ_GENERATE_REPORT_QUEUE=reporter.generate-report.queue
RABBITMQ_GENERATE_REPORT_KEY=reporter.generate-report.key
RABBITMQ_HEALTH_CHECK_URL=http://${RABBITMQ_HOST}:${RABBITMQ_PORT_HOST}
# Worker surface only:
RABBITMQ_NUMBERS_OF_WORKERS=5
RABBITMQ_DLQ_QUEUE=reporter.dlq
#RABBITMQ_TLS=false

# Object Storage — S3-compatible. The SeaweedFS service is reporter-only net-new
# infra owned by Phase 8 (config staged at components/infra/seaweedfs/); the
# endpoint below targets that future service on infra-network. Until P8 brings it
# up, point OBJECT_STORAGE_ENDPOINT at any S3-compatible endpoint on infra-network.
OBJECT_STORAGE_ENDPOINT=http://midaz-seaweedfs:8333
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=any
OBJECT_STORAGE_SECRET_KEY=any
OBJECT_STORAGE_USE_PATH_STYLE=true
OBJECT_STORAGE_DISABLE_SSL=true
OBJECT_STORAGE_BUCKET=reporter-storage

# Redis — points at midaz's shared infra valkey service (components/infra).
# Required for the API surface; the worker uses it for multi-tenant tenant
# discovery cache.
REDIS_HOST=midaz-valkey:5704
REDIS_PASSWORD=lerian
REDIS_DB=0
REDIS_PROTOCOL=3
REDIS_TLS=false
REDIS_CA_CERT=
REDIS_MASTER_NAME=
REDIS_USE_GCP_IAM=false
REDIS_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=

# OpenTelemetry
# In production, RUN_MODE and OTEL_RESOURCE_SERVICE_NAME are set per-Deployment
# (one image, two surfaces) so api and worker pods report under distinct service
# names. The value below is the local/dev default for the unified process.
OTEL_RESOURCE_SERVICE_NAME=reporter
OTEL_LIBRARY_NAME=github.com/LerianStudio/midaz/v4/components/reporter
OTEL_RESOURCE_SERVICE_VERSION="${VERSION}"
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT="${ENV_NAME}"
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT="otlp://otel-lgtm:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}"
ENABLE_TELEMETRY=false
OTEL_INSECURE_EXPORTER=false

# Swagger (API surface)
SWAGGER_TITLE='Reporter API'
SWAGGER_DESCRIPTION='Documentation for reporter'
SWAGGER_VERSION="${VERSION}"
SWAGGER_HOST="${SERVER_ADDRESS}"
SWAGGER_BASE_PATH=/
SWAGGER_SCHEMES=http
SWAGGER_LEFT_DELIMITER={{
SWAGGER_RIGHT_DELIMITER=}}

# Authorization
PLUGIN_AUTH_ADDRESS=http://plugin-auth:4000
PLUGIN_AUTH_ENABLED=false

# PDF Generation (worker surface)
PDF_POOL_WORKERS=5
PDF_TIMEOUT_SECONDS=30

# CRM Crypto (worker surface) — decryption keys for crm datasource (optional, only needed with crm)
CRYPTO_HASH_SECRET_KEY_CRM=CHANGE_ME
CRYPTO_ENCRYPT_SECRET_KEY_CRM=CHANGE_ME

# Direct Datasources — single-tenant direct query mode. Schema discovery and
# extraction always run in-process (there is no remote fetcher hop).
# DATASOURCE_ONBOARDING_CONFIG_NAME=midaz_onboarding
# DATASOURCE_ONBOARDING_HOST=midaz-postgres-replica
# DATASOURCE_ONBOARDING_PORT=5702
# DATASOURCE_ONBOARDING_USER=midaz
# DATASOURCE_ONBOARDING_PASSWORD=CHANGE_ME
# DATASOURCE_ONBOARDING_DATABASE=onboarding
# DATASOURCE_ONBOARDING_TYPE=postgresql
# DATASOURCE_ONBOARDING_SSLMODE=disable
# DATASOURCE_ONBOARDING_SSLROOTCERT=

# Direct Datasource with multiple schemas — use DATASOURCE_<NAME>_SCHEMAS (comma-separated)
#DATASOURCE_EXTERNAL_CONFIG_NAME=external_db
#DATASOURCE_EXTERNAL_HOST=external-postgres
#DATASOURCE_EXTERNAL_PORT=5432
#DATASOURCE_EXTERNAL_USER=db_user
#DATASOURCE_EXTERNAL_PASSWORD=CHANGE_ME
#DATASOURCE_EXTERNAL_DATABASE=external_database
#DATASOURCE_EXTERNAL_TYPE=postgresql
#DATASOURCE_EXTERNAL_SSLMODE=disable
#DATASOURCE_EXTERNAL_SSLROOTCERT=
#DATASOURCE_EXTERNAL_DB_SCHEMAS=sales,inventory,reporting

# Multi-Tenant — when enabled, Reporter resolves tenant context from requests and isolates resources
MULTI_TENANT_ENABLED=false
#MULTI_TENANT_URL=http://tenant-manager:8080
#MULTI_TENANT_ENVIRONMENT=staging
#MULTI_TENANT_SERVICE_API_KEY=
#MULTI_TENANT_TIMEOUT=30
#MULTI_TENANT_CACHE_TTL_SEC=120
#MULTI_TENANT_MAX_TENANT_POOLS=100
#MULTI_TENANT_IDLE_TIMEOUT_SEC=300
#MULTI_TENANT_CIRCUIT_BREAKER_THRESHOLD=5
#MULTI_TENANT_CIRCUIT_BREAKER_TIMEOUT_SEC=30
#MULTI_TENANT_REDIS_HOST=
#MULTI_TENANT_REDIS_PORT=6379
#MULTI_TENANT_REDIS_PASSWORD=
#MULTI_TENANT_REDIS_TLS=false
#MULTI_TENANT_REDIS_CA_CERT=  # Base64-encoded PEM (optional, used when MULTI_TENANT_REDIS_TLS=true)
#MULTI_TENANT_ALLOW_INSECURE_HTTP=false
#RABBITMQ_MULTI_TENANT_SYNC_INTERVAL=30
#RABBITMQ_MULTI_TENANT_DISCOVERY_TIMEOUT=500
