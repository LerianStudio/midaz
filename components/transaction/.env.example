# TRANSACTION

# Migration note (RabbitMQ -> Redpanda): regenerate local .env from this file
# and remove any legacy RABBITMQ_* variables.

# DEFAULT local
ENV_NAME=development

# APP
VERSION=v3.5.1

SERVER_PORT=3001
SERVER_ADDRESS=:${SERVER_PORT}

# PROTOBUF (gRPC server address, e.g., ":3011" or "0.0.0.0:3011")
# If not set, defaults to :3011
PROTO_ADDRESS=:3011

# AUTH CONFIGS
PLUGIN_AUTH_ENABLED=false
PLUGIN_AUTH_HOST=

# AUTHORIZER (optional write-path replacement for Redis Lua)
AUTHORIZER_ENABLED=false
AUTHORIZER_HOST=127.0.0.1
AUTHORIZER_PORT=50051
# AUTHORIZER_TIMEOUT_MS covers cross-shard 2PC (peer Prepare + peer Commit RTTs) + WAL fsync +
# GC pauses at the p99. Single-shard deployments can safely lower this. Do not set below 150ms.
AUTHORIZER_TIMEOUT_MS=250
AUTHORIZER_USE_STREAMING=false
AUTHORIZER_TLS_ENABLED=false
# REQUIRED when AUTHORIZER_ENABLED=true. Generate a strong shared secret:
#   openssl rand -hex 32
AUTHORIZER_PEER_AUTH_TOKEN=
# Enable TLS for gRPC authorizer connection (MANDATORY for production)

# ACCOUNTING CONFIG
# List of <organization-id>:<ledger-id> separated by comma
TRANSACTION_ROUTE_VALIDATION=

# DB POSTGRESQL PRIMARY AND REPLICA
DB_HOST=midaz-postgres-primary
DB_USER=midaz
DB_NAME=transaction
DB_PASSWORD=lerian
DB_PORT=5701
# SSLMODE Options: disable (dev only!) | require (MANDATORY for production)
DB_SSLMODE=disable

DB_REPLICA_HOST=midaz-postgres-replica
DB_REPLICA_USER=midaz
DB_REPLICA_NAME=transaction
DB_REPLICA_PASSWORD=lerian
DB_REPLICA_PORT=5702
# SSLMODE Options: disable (dev only!) | require (MANDATORY for production)
DB_REPLICA_SSLMODE=disable

# Per-instance pool caps (D7). Default 100 open / 50 idle keeps a single
# service instance well under typical PG max_connections even before
# PgBouncer fan-in. Raise only after computing the aggregate budget via
# DB_POOL_BUDGET_* and confirming PG max_connections has headroom.
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=50

# Pool budget validation (D7). When DB_POOL_BUDGET_MAX_CONNECTIONS is > 0
# the bootstrap rejects startup if MaxOpenConns * DB_POOL_BUDGET_INSTANCES
# exceeds DB_POOL_BUDGET_MAX_CONNECTIONS * DB_POOL_BUDGET_RATIO. Keep at 0
# (disabled) for local dev; set to the PG max_connections in prod.
DB_POOL_BUDGET_MAX_CONNECTIONS=0
DB_POOL_BUDGET_INSTANCES=1
DB_POOL_BUDGET_RATIO_PERCENT=80

# MONGO DB
#MONGO_URI=mongodb+srv
MONGO_URI=mongodb
MONGO_HOST=midaz-mongodb
MONGO_NAME=transaction
MONGO_USER=midaz
MONGO_PASSWORD=lerian
MONGO_PORT=5703
MONGO_MAX_POOL_SIZE=1000
MONGO_PARAMETERS=

# REDIS
# SENTINEL
# REDIS_HOST=midaz-valkey-sentinel-1:5704,midaz-valkey-sentinel-2:5704
# CLUSTER
# REDIS_HOST=midaz-valkey:5704,midaz-valkey:5704
# STANDALONE
REDIS_HOST=midaz-valkey:5704

# USE ONLY ON SENTINEL
REDIS_MASTER_NAME=

REDIS_TLS=false
REDIS_CA_CERT=

REDIS_USE_GCP_IAM=false
REDIS_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=
# <= 60 minutes
REDIS_TOKEN_LIFETIME=60
# minutes
REDIS_TOKEN_REFRESH_DURATION=45
REDIS_PASSWORD=lerian
REDIS_DB=0
REDIS_PROTOCOL=3

# REDIS POOL & RETRY CONFIGS
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=0
# Seconds
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
REDIS_DIAL_TIMEOUT=5
REDIS_POOL_TIMEOUT=2

REDIS_MAX_RETRIES=3
# Milliseconds
REDIS_MIN_RETRY_BACKOFF=8
# Seconds
REDIS_MAX_RETRY_BACKOFF=1

# LOG LEVEL
LOG_LEVEL=debug

# OPEN TELEMETRY
OTEL_RESOURCE_SERVICE_NAME=transaction
OTEL_LIBRARY_NAME=github.com/LerianStudio/midaz/v3/components/transaction
OTEL_RESOURCE_SERVICE_VERSION=${VERSION}
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=${ENV_NAME}
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT=midaz-otel-lgtm:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}
ENABLE_TELEMETRY=false

# REDPANDA / KAFKA
REDPANDA_BROKERS=midaz-redpanda:9092
REDPANDA_BALANCE_CREATE_TOPIC=ledger.balance.create
REDPANDA_BALANCE_OPS_TOPIC=ledger.balance.operations
REDPANDA_EVENTS_TOPIC=ledger.transaction.events
# Optional dedicated topic for transaction decision lifecycle events.
# When empty, decision lifecycle events fall back to REDPANDA_EVENTS_TOPIC.
REDPANDA_DECISION_EVENTS_TOPIC=
REDPANDA_AUDIT_TOPIC=ledger.audit.log
REDPANDA_CONSUMER_GROUP=midaz-balance-projector
REDPANDA_NUMBERS_OF_WORKERS=5
REDPANDA_FETCH_MAX_BYTES=50000000
REDPANDA_PRODUCER_LINGER_MS=5
REDPANDA_MAX_BUFFERED_RECORDS=10000
# Number of topic partitions. Must match the topic creation script (create-topics.sh).
REDPANDA_PARTITION_COUNT=8

# CACHE INVALIDATION CONSUMER
# Subscribes to the authorizer's cache-invalidation topic and DELs stale
# Redis balance entries after cross-shard 2PC recovery completes on a peer.
# Default enabled — disable only when the transaction service runs without
# authorizer integration.
CACHE_INVALIDATION_CONSUMER_ENABLED=true
CACHE_INVALIDATION_CONSUMER_GROUP=transaction-cache-invalidation
CACHE_INVALIDATION_TOPIC=authorizer.cross-shard.cache-invalidation
CACHE_INVALIDATION_MAX_TRANSIENT_RETRIES=5

# TRANSACTION ASYNC MODE
TRANSACTION_ASYNC=false

# CONSUMER MODE
# Embedded mode (single binary): CONSUMER_ENABLED=true, DEDICATED_CONSUMER_ENABLED=false
# Dedicated mode (split API + consumer): CONSUMER_ENABLED=false, DEDICATED_CONSUMER_ENABLED=true
CONSUMER_ENABLED=true
DEDICATED_CONSUMER_ENABLED=false

# AUTHORIZER ROUTING (sharded mode for multi-instance authorizer deployments)
# "single" = one authorizer instance (default), "sharded" = shard-aware routing
AUTHORIZER_ROUTING_MODE=single
# Comma-separated authorizer instance addresses (host:port) for sharded mode
AUTHORIZER_INSTANCES=
# Shard ranges per instance, e.g. "0-3,4-7" (one range per instance, no overlap)
AUTHORIZER_SHARD_RANGES=
# Enable TLS for gRPC authorizer connection (MANDATORY in production)
AUTHORIZER_GRPC_TLS_ENABLED=false

# CONSUMER LAG FENCE
# Blocks balance queries when consumer is behind, preventing stale reads.
CONSUMER_LAG_FENCE_ENABLED=true
# Fail-open: allow queries when lag status is unknown (e.g. fresh deploy, no committed offsets).
# Default false for secure-by-default stale-read protection.
CONSUMER_LAG_FENCE_FAIL_OPEN=false
# TTL for cached lag status in milliseconds
CONSUMER_LAG_CACHE_TTL_MS=500

# CONSUMER BACKPRESSURE
# Rate-limits DB writes from consumer workers to prevent PostgreSQL overload.
CONSUMER_BACKPRESSURE_ENABLED=false
CONSUMER_MAX_DB_TPS=0
CONSUMER_MAX_DB_BURST=100

# CONSUMER BATCH MODE
# Micro-batches multiple Kafka messages into a single DB transaction.
CONSUMER_BATCH_ENABLED=false
CONSUMER_BATCH_SIZE=50
CONSUMER_BATCH_WINDOW_MS=10
CONSUMER_IDLE_FLUSH_MS=100
CONSUMER_BATCH_IMMEDIATE_COMMIT=true

# POST-COMMIT SIDE EFFECTS
# Timeout (ms) for Redis cleanup and event publishing after batch DB commit.
BATCH_SIDE_EFFECTS_TIMEOUT_MS=2000

# IDEMPOTENCY
# Timeout (ms) for polling an in-flight idempotency value from Redis.
# Increase for high-TPS scenarios where 75ms is too tight.
IDEMPOTENCY_REPLAY_TIMEOUT_MS=75

# BROKER OPERATION TIMEOUT
BROKER_OPERATION_TIMEOUT=3s

# TRANSACTION EVENTS
TRANSACTION_EVENTS_ENABLED=false

# AUDIT DEFAULT OFF
AUDIT_LOG_ENABLED=false

# SWAGGER
SWAGGER_TITLE=Transaction API
SWAGGER_DESCRIPTION=Documentation for the Midaz Transaction API
SWAGGER_VERSION=${VERSION}
SWAGGER_HOST=${SERVER_ADDRESS}
SWAGGER_BASE_PATH=/
SWAGGER_SCHEMES=http
SWAGGER_LEFT_DELIMITER={{
SWAGGER_RIGHT_DELIMITER=}}
# Disable Swagger entirely in production (defaults to true in dev/local/test, false in strict envs)
# SWAGGER_ENABLED=true
# Token required to access Swagger UI (when empty, no token is required)
# SWAGGER_AUTH_TOKEN=

# CORS
# Comma-separated list of allowed origins for CORS (in strict envs, defaults to denied if empty)
# Example: https://app.example.com,https://admin.example.com
# In dev/local/test environments defaults to http://localhost,http://127.0.0.1
# CORS_ALLOWED_ORIGINS=*

# PAGINATION
MAX_PAGINATION_LIMIT=100
MAX_PAGINATION_MONTH_DATE_RANGE=1

# BALANCE SYNC WORKER
# When enabled, balances are scheduled for sync to PostgreSQL before Redis TTL expires.
# Default: true (if not set, the worker is enabled)
# BALANCE_SYNC_WORKER_ENABLED=true
BALANCE_SYNC_MAX_WORKERS=5

# REDIS SHARDING + AUTO-REBALANCING (Phase 2B)
# Set > 0 to enable Redis shard routing (e.g., 8)
REDIS_SHARD_COUNT=0
# Redis TTL for query-side balance cache refreshes from stale-replay/authorizer.
# 0 means no expiration.
BALANCE_CACHE_TTL_SECONDS=0
# Enable automatic hot-account migration worker
SHARD_REBALANCE_WORKER_ENABLED=false
# Rebalance loop interval in seconds
SHARD_REBALANCE_INTERVAL_SECONDS=5
# Rolling load window in seconds
SHARD_REBALANCE_WINDOW_SECONDS=60
# Trigger threshold as percentage of average shard load (150 = 1.5x)
SHARD_REBALANCE_THRESHOLD_PERCENT=150
# Number of hot-account candidates evaluated per cycle
SHARD_REBALANCE_CANDIDATE_LIMIT=8
# Isolation threshold (% of hot shard load) for dedicated-shard placement
SHARD_REBALANCE_ISOLATION_SHARE_PERCENT=70
# Minimum account load in window required for isolation mode
SHARD_REBALANCE_ISOLATION_MIN_LOAD=250
# Control-plane token for sharding admin endpoints (/v1/sharding/**)
# MANDATORY: generate a cryptographically random token >= 32 chars before enabling sharding
# Example: openssl rand -hex 32
SHARDING_ADMIN_TOKEN=
# Control-plane request rate limit (per IP)
SHARDING_ADMIN_RATE_LIMIT_MAX=30
SHARDING_ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# External pre-split balance pre-warm at startup
EXTERNAL_PRESPLIT_PREWARM=true
EXTERNAL_PRESPLIT_PREWARM_TTL_SECONDS=3600
EXTERNAL_PRESPLIT_SHARD_COUNT=8
EXTERNAL_PRESPLIT_ORGANIZATION_ID=
EXTERNAL_PRESPLIT_LEDGER_ID=

# BROKER CIRCUIT BREAKER
# Protects against broker outages by failing fast when Redpanda is unavailable.
# The circuit breaker is always enabled; these settings control its behavior.
# ConsecutiveFailures: Number of consecutive failures before circuit opens (default: 15)
BROKER_CIRCUIT_BREAKER_CONSECUTIVE_FAILURES=15
# FailureRatio: Percentage (0-100) of failures to trigger open state (default: 50)
BROKER_CIRCUIT_BREAKER_FAILURE_RATIO=50
# Interval: Time window for failure counting in seconds (default: 120)
BROKER_CIRCUIT_BREAKER_INTERVAL=120
# MaxRequests: Requests allowed in half-open state (default: 3)
BROKER_CIRCUIT_BREAKER_MAX_REQUESTS=3
# MinRequests: Minimum requests before evaluating failure ratio (default: 10)
BROKER_CIRCUIT_BREAKER_MIN_REQUESTS=10
# Timeout: Wait time before transitioning from open to half-open in seconds (default: 30)
BROKER_CIRCUIT_BREAKER_TIMEOUT=30
