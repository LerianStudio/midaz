ENV_NAME=development

# APP
VERSION=v3.5.1
SERVER_PORT=4003
SERVER_ADDRESS=:${SERVER_PORT}

# MONGO DB
#MONGO_URI=mongo+srv
MONGO_URI=mongodb
MONGO_HOST=midaz-mongodb
MONGO_NAME=crm
MONGO_USER=midaz
MONGO_PASSWORD=lerian
MONGO_PORT=5703
MONGO_MAX_POOL_SIZE=1000
MONGO_PARAMETERS=

# SWAGGER
SWAGGER_TITLE=CRM API
SWAGGER_DESCRIPTION=The CRM API provides a set of endpoints for managing holder data, including information related to their ledger accounts.
SWAGGER_VERSION=${VERSION}
SWAGGER_HOST=${SERVER_ADDRESS}
SWAGGER_BASE_PATH=/
SWAGGER_SCHEMES=http
SWAGGER_LEFT_DELIMITER={{
SWAGGER_RIGHT_DELIMITER=}}

# LOG LEVEL
LOG_LEVEL=debug

# OPEN TELEMETRY
OTEL_RESOURCE_SERVICE_NAME=crm
OTEL_LIBRARY_NAME=github.com/LerianStudio/midaz/v3/components/crm
OTEL_RESOURCE_SERVICE_VERSION=${VERSION}
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=${ENV_NAME}
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT=otlp://midaz-otel-lgtm:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}
ENABLE_TELEMETRY=false

# DATA SECURITY
LCRYPTO_HASH_SECRET_KEY=my-hash-secret-key
LCRYPTO_ENCRYPT_SECRET_KEY=my-encrypt-secret-key

# AUTH
PLUGIN_AUTH_ADDRESS=http://plugin-auth:4000
PLUGIN_AUTH_ENABLED=false

# APPLICATION
APPLICATION_NAME=ledger

# MULTI-TENANT
# When enabled, the CRM resolves per-tenant database connections via the Tenant Manager API.
# Default: disabled (single-tenant mode, identical to current behavior)
MULTI_TENANT_ENABLED=false
# MULTI_TENANT_URL=http://tenant-manager:4003
# MULTI_TENANT_TIMEOUT=30
# MULTI_TENANT_CIRCUIT_BREAKER_THRESHOLD=5
# MULTI_TENANT_CIRCUIT_BREAKER_TIMEOUT_SEC=30
# MULTI_TENANT_MAX_TENANT_POOLS=100
# MULTI_TENANT_IDLE_TIMEOUT_SEC=300
# MULTI_TENANT_SERVICE_API_KEY=
# MULTI_TENANT_REDIS_HOST=
# MULTI_TENANT_REDIS_PORT=6379
# MULTI_TENANT_REDIS_PASSWORD=
MULTI_TENANT_REDIS_TLS=false
