# AUTHORIZER

# Migration note (RabbitMQ -> Redpanda): regenerate local .env from this file
# and remove any RABBITMQ_* / AUTHORIZER_RABBITMQ_* variables.

ENV_NAME=development
LOG_LEVEL=debug

# gRPC server
AUTHORIZER_GRPC_ADDRESS=:50051
AUTHORIZER_SHARD_COUNT=8
AUTHORIZER_GRPC_REFLECTION_ENABLED=false

# Runtime
GOMAXPROCS=4

# Telemetry (OpenTelemetry)
ENABLE_TELEMETRY=false
OTEL_RESOURCE_SERVICE_NAME=authorizer
OTEL_LIBRARY_NAME=midaz-authorizer
OTEL_RESOURCE_SERVICE_VERSION=v3
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# WAL (always-on, secure by design)
AUTHORIZER_WAL_PATH=/tmp/midaz-authorizer-wal.log
AUTHORIZER_WAL_BUFFER_SIZE=65536
AUTHORIZER_WAL_FLUSH_INTERVAL_MS=1
AUTHORIZER_WAL_SYNC_ON_APPEND=true
AUTHORIZER_PREPARE_TIMEOUT_MS=30000
AUTHORIZER_PREPARE_MAX_PENDING=10000
AUTHORIZER_MAX_OPERATIONS_PER_REQUEST=2048
AUTHORIZER_MAX_UNIQUE_BALANCES_PER_REQUEST=2048
AUTHORIZER_WAL_REPLAY_MAX_MUTATIONS_PER_ENTRY=2048
AUTHORIZER_WAL_REPLAY_MAX_UNIQUE_BALANCES_PER_ENTRY=2048
# Set to true in production (code default). false here for easier local development iteration.
AUTHORIZER_WAL_REPLAY_STRICT_MODE=false
AUTHORIZER_PREPARED_COMMITTED_RETENTION_MS=86400000
AUTHORIZER_PREPARE_COMMIT_RETRY_LIMIT=3

# Redpanda publishing (authorizer owns BTO publish)
AUTHORIZER_REDPANDA_ENABLED=true
AUTHORIZER_REDPANDA_BROKERS=localhost:9092
AUTHORIZER_REDPANDA_PRODUCER_LINGER_MS=5
AUTHORIZER_REDPANDA_MAX_BUFFERED_RECORDS=10000
AUTHORIZER_REDPANDA_RECORD_RETRIES=3
AUTHORIZER_REDPANDA_DELIVERY_TIMEOUT_MS=30000
AUTHORIZER_REDPANDA_PUBLISH_TIMEOUT_MS=5000
AUTHORIZER_REDPANDA_BACKPRESSURE_POLICY=bounded_wait
AUTHORIZER_COMMIT_INTENT_CONSUMER_GROUP=authorizer-cross-shard-recovery
AUTHORIZER_COMMIT_INTENT_POLL_TIMEOUT_MS=1000

# PostgreSQL (transaction database)
DB_TRANSACTION_HOST=localhost
DB_TRANSACTION_PORT=5432
DB_TRANSACTION_USER=midaz
DB_TRANSACTION_PASSWORD=lerian
DB_TRANSACTION_NAME=transaction
DB_TRANSACTION_SSLMODE=disable
AUTHORIZER_DB_MAX_CONNS=20
AUTHORIZER_DB_MIN_CONNS=2
AUTHORIZER_DB_MAX_CONN_LIFETIME_MS=1800000
AUTHORIZER_DB_MAX_CONN_IDLE_MS=300000
AUTHORIZER_DB_HEALTHCHECK_MS=30000
AUTHORIZER_DB_CONNECT_TIMEOUT_MS=5000

# Peer 2PC (set only for multi-instance sharded mode)
# AUTHORIZER_INSTANCE_ADDRESS=authorizer:50051
# AUTHORIZER_PEER_INSTANCES=authorizer-2:50051
# AUTHORIZER_PEER_SHARD_RANGES=4-7
# AUTHORIZER_OWNED_SHARD_START=0
# AUTHORIZER_OWNED_SHARD_END=3
# REQUIRED when peers are configured. Generate a strong shared secret:
#   openssl rand -hex 32
# AUTHORIZER_PEER_AUTH_TOKEN=replace-with-strong-shared-secret
# AUTHORIZER_PEER_AUTH_TOKEN_PREVIOUS=optional-previous-token-for-rotation
AUTHORIZER_PEER_PREPARE_MAX_INFLIGHT=1024
AUTHORIZER_PEER_AUTH_MAX_SKEW_MS=30000
AUTHORIZER_PEER_NONCE_MAX_ENTRIES=100000
AUTHORIZER_PEER_ABORT_TIMEOUT_MS=5000
AUTHORIZER_PEER_COMMIT_TIMEOUT_MS=10000
AUTHORIZER_PEER_INSECURE_ALLOWED=false
# AUTHORIZER_PEER_TLS_CA_FILE=/etc/ssl/certs/peer-ca.pem

# Performance tuning (cross-shard 2PC)
AUTHORIZER_PEER_PREPARE_BOUNDED_WAIT_MS=50
AUTHORIZER_PEER_CONN_POOL_SIZE=4
AUTHORIZER_ASYNC_COMMIT_INTENT=false

# WAL Reconciler (periodic scan for un-confirmed WAL entries)
AUTHORIZER_WAL_RECONCILER_ENABLED=false
AUTHORIZER_WAL_RECONCILER_INTERVAL_MS=10000
AUTHORIZER_WAL_RECONCILER_LOOKBACK_MS=300000
AUTHORIZER_WAL_RECONCILER_GRACE_MS=30000
AUTHORIZER_WAL_RECONCILER_COMPLETED_TTL_MS=600000

# Fallback DB_* vars (used when DB_TRANSACTION_* is not provided)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=
