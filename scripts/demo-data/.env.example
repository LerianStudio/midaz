# Midaz Demo Data Generator Configuration
# Copy this file to .env and modify the values as needed

# =============================================================================
# API Configuration
# =============================================================================

# Midaz API base URL (required)
DEMO_DATA_API_BASE_URL=https://api.midaz.io

# Authentication token for Midaz API (required)
# Get this from your Midaz dashboard or admin
DEMO_DATA_AUTH_TOKEN=your_auth_token_here

# Request timeout for API calls (default: 30s)
# Format: duration string (e.g., "30s", "1m", "90s")
DEMO_DATA_TIMEOUT_DURATION=30s

# =============================================================================
# Application Configuration
# =============================================================================

# Debug mode - enables detailed logging and debug features (default: false)
DEMO_DATA_DEBUG=false

# Log level for application logging (default: info)
# Options: debug, info, warn, error
DEMO_DATA_LOG_LEVEL=info

# =============================================================================
# Data Volume Configuration - Small Scale
# =============================================================================

# Small volume settings for testing and development
# Estimated total: ~400 accounts, ~8K transactions
DEMO_DATA_VOLUME_CONFIG_SMALL_ORGANIZATIONS=2
DEMO_DATA_VOLUME_CONFIG_SMALL_LEDGERS_PER_ORG=2
DEMO_DATA_VOLUME_CONFIG_SMALL_ASSETS_PER_LEDGER=3
DEMO_DATA_VOLUME_CONFIG_SMALL_PORTFOLIOS_PER_LEDGER=2
DEMO_DATA_VOLUME_CONFIG_SMALL_SEGMENTS_PER_LEDGER=2
DEMO_DATA_VOLUME_CONFIG_SMALL_ACCOUNTS_PER_LEDGER=100
DEMO_DATA_VOLUME_CONFIG_SMALL_TRANSACTIONS_PER_ACCOUNT=20

# =============================================================================
# Data Volume Configuration - Medium Scale
# =============================================================================

# Medium volume settings for load testing and demos
# Estimated total: ~7.5K accounts, ~375K transactions
DEMO_DATA_VOLUME_CONFIG_MEDIUM_ORGANIZATIONS=5
DEMO_DATA_VOLUME_CONFIG_MEDIUM_LEDGERS_PER_ORG=3
DEMO_DATA_VOLUME_CONFIG_MEDIUM_ASSETS_PER_LEDGER=5
DEMO_DATA_VOLUME_CONFIG_MEDIUM_PORTFOLIOS_PER_LEDGER=3
DEMO_DATA_VOLUME_CONFIG_MEDIUM_SEGMENTS_PER_LEDGER=4
DEMO_DATA_VOLUME_CONFIG_MEDIUM_ACCOUNTS_PER_LEDGER=500
DEMO_DATA_VOLUME_CONFIG_MEDIUM_TRANSACTIONS_PER_ACCOUNT=50

# =============================================================================
# Data Volume Configuration - Large Scale
# =============================================================================

# Large volume settings for stress testing and production simulation
# Estimated total: ~50K accounts, ~5M transactions
DEMO_DATA_VOLUME_CONFIG_LARGE_ORGANIZATIONS=10
DEMO_DATA_VOLUME_CONFIG_LARGE_LEDGERS_PER_ORG=5
DEMO_DATA_VOLUME_CONFIG_LARGE_ASSETS_PER_LEDGER=8
DEMO_DATA_VOLUME_CONFIG_LARGE_PORTFOLIOS_PER_LEDGER=5
DEMO_DATA_VOLUME_CONFIG_LARGE_SEGMENTS_PER_LEDGER=6
DEMO_DATA_VOLUME_CONFIG_LARGE_ACCOUNTS_PER_LEDGER=1000
DEMO_DATA_VOLUME_CONFIG_LARGE_TRANSACTIONS_PER_ACCOUNT=100

# =============================================================================
# Development Notes
# =============================================================================

# 1. All configuration values can be overridden by command-line flags
# 2. Environment variables take precedence over file values
# 3. Command-line flags take precedence over environment variables
# 4. The DEMO_DATA_ prefix is required for all environment variables
# 5. Nested configuration uses underscores (e.g., VOLUME_CONFIG_SMALL_ORGANIZATIONS)
#
# Example usage:
#   export DEMO_DATA_AUTH_TOKEN="your_token"
#   export DEMO_DATA_DEBUG=true
#   ./demo-data validate
#
# Or with command-line flags:
#   ./demo-data --auth-token="your_token" --debug validate